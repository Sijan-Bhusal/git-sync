#!/usr/bin/env bash
set -euo pipefail

DEVICE_NAME="Arch"
BRANCH=""

# ──────────────────────────────────────────────
#  gum-based UI helpers
# ──────────────────────────────────────────────
header() {
  gum style --border double --padding "1 2" --margin "0 0 1 0" \
    --foreground 212 --border-foreground 212 \
    "📓 Git Sync" "Device: $DEVICE_NAME"
}

info()   { gum style --foreground 39 "▸ $1"; }
ok()     { gum style --foreground 42 "✔ $1"; }
warn()   { gum style --foreground 214 "⚠ $1"; }
error()  { gum style --foreground 196 "✖ $1"; }
fatal()  { error "$1"; exit 1; }

spin() {
  gum spin --spinner dot --title "$1" --show-error -- "${@:2}"
}

confirm_danger() {
  gum confirm --affirmative "Yes, $1" --negative "Cancel" --default=false \
    "$2"
}

# ──────────────────────────────────────────────
#  Guard: must be a git repo
# ──────────────────────────────────────────────
git rev-parse --git-dir > /dev/null 2>&1 || fatal "Not a git repository"

# ──────────────────────────────────────────────
#  Determine branch & remote
# ──────────────────────────────────────────────
[ -z "$BRANCH" ] && BRANCH=$(git rev-parse --abbrev-ref HEAD)

REMOTE=$(git config "branch.$BRANCH.remote" || true)
[ -z "$REMOTE" ] && fatal "No remote configured for branch '$BRANCH'. Run: git push -u origin $BRANCH"

UPSTREAM="${REMOTE}/${BRANCH}"
TIMESTAMP=$(date '+%b-%d')
COMMIT_MSG="Last Sync: $TIMESTAMP ($DEVICE_NAME)"

# ──────────────────────────────────────────────
#  Render header
# ──────────────────────────────────────────────
header

# ──────────────────────────────────────────────
#  Commit pending changes
# ──────────────────────────────────────────────
if git diff --quiet && git diff --cached --quiet; then
  info "No changes to commit"
else
  git add -A
  git commit -m "$COMMIT_MSG"
  ok "Committed: $COMMIT_MSG"
fi

# ──────────────────────────────────────────────
#  Fetch
# ──────────────────────────────────────────────
info "Fetching from $REMOTE..."
spin "Fetching from $REMOTE..." git fetch "$REMOTE" || fatal "Fetch failed"
ok "Fetch complete"

# ──────────────────────────────────────────────
#  Determine sync state
# ──────────────────────────────────────────────
AHEAD=$(git rev-list --count "$UPSTREAM..HEAD" 2>/dev/null || echo 0)
BEHIND=$(git rev-list --count "HEAD..$UPSTREAM" 2>/dev/null || echo 0)

if [ "$AHEAD" -eq 0 ] && [ "$BEHIND" -eq 0 ]; then
  ok "Everything is in sync"
  exit 0
fi

if [ "$AHEAD" -gt 0 ] && [ "$BEHIND" -gt 0 ]; then
  STATE="diverged"
  info "Local is ${AHEAD} ahead, remote is ${BEHIND} behind"
  warn "Branch has diverged"
elif [ "$AHEAD" -gt 0 ]; then
  STATE="ahead"
  info "Local is ${AHEAD} commit(s) ahead of remote"
else
  STATE="behind"
  info "Remote is ${BEHIND} commit(s) ahead of local"
fi

# ──────────────────────────────────────────────
#  Action menu
# ──────────────────────────────────────────────
echo

choose_action() {
  gum choose --cursor "→ " --header "What would you like to do?" --height 10 \
    "$@"
}

case "$STATE" in
  ahead)
    choice=$(choose_action \
      "Upload changes (push)" \
      "Sync (pull + push)" \
      "Upload + overwrite remote (force push)" \
      "Cancel")
    ;;
  behind)
    choice=$(choose_action \
      "Download changes (pull --rebase)" \
      "Sync (pull + push)" \
      "Download + overwrite local (reset)" \
      "Cancel")
    ;;
  diverged)
    choice=$(choose_action \
      "Upload changes (push)" \
      "Sync (pull + push)" \
      "Upload + overwrite remote (force push)" \
      "Download changes (pull --rebase)" \
      "Download + overwrite local (reset)" \
      "Cancel")
    ;;
esac

# ──────────────────────────────────────────────
#  Execute action
# ──────────────────────────────────────────────
echo

case "$choice" in
  "Upload changes (push)")
    spin "Pushing to $REMOTE/$BRANCH..." git push "$REMOTE" "$BRANCH"
    ok "Push complete"
    ;;

  "Sync (pull + push)")
    spin "Pulling from $REMOTE/$BRANCH..." git pull --rebase "$REMOTE" "$BRANCH"
    spin "Pushing to $REMOTE/$BRANCH..." git push "$REMOTE" "$BRANCH"
    ok "Sync complete"
    ;;

  "Upload + overwrite remote (force push)")
    warn "This will DISCARD remote commits that aren't local."
    if confirm_danger "force push" "Proceed with force push?"; then
      spin "Force pushing to $REMOTE/$BRANCH..." git push --force "$REMOTE" "$BRANCH"
      ok "Force push complete"
    else
      info "Cancelled"
      exit 0
    fi
    ;;

  "Download changes (pull --rebase)")
    spin "Pulling from $REMOTE/$BRANCH..." git pull --rebase "$REMOTE" "$BRANCH"
    ok "Pull complete"
    ;;

  "Download + overwrite local (reset)")
    warn "This will DISCARD local changes that aren't in the remote."
    if confirm_danger "reset" "Reset local to $UPSTREAM?"; then
      git reset --hard "$UPSTREAM"
      ok "Reset to $UPSTREAM complete"
    else
      info "Cancelled"
      exit 0
    fi
    ;;

  ""|"Cancel")
    info "Cancelled"
    exit 0
    ;;

  *)
    error "Invalid choice"
    exit 1
    ;;
esac
